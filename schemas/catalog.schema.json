{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gentle Bridge Dictionary Pack Catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "packs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "packs": {
      "type": "array",
      "items": { "$ref": "pack-manifest.schema.json" }
    }
  }
}
