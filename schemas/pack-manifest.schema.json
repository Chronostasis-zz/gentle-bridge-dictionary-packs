{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gentle Bridge Dictionary Pack Manifest",
  "type": "object",
  "required": ["id", "schemaVersion", "dataVersion", "sourceLanguage", "targetLanguage", "assetUrl", "sizeBytes", "checksumSha256", "entryCount", "generatedAt", "sources"],
  "properties": {
    "id": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "dataVersion": { "type": "string" },
    "sourceLanguage": { "type": "string" },
    "targetLanguage": { "type": "string" },
    "assetUrl": { "type": "string", "format": "uri" },
    "sizeBytes": { "type": "integer", "minimum": 1 },
    "checksumSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "entryCount": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sources": { "type": "array", "minItems": 1 }
  }
}
